generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FlightSource {
  DUFFEL
  AMADEUS   // deprecated, dipertahankan utk historical price records
  LIONAIR
  CITILINK
  AIRASIA
  SUPERAIRJET
}

enum CabinClass {
  ECONOMY
  PREMIUM_ECONOMY
  BUSINESS
  FIRST
}

model PriceRecord {
  id           String       @id @default(uuid())
  source       FlightSource
  origin       String       @db.VarChar(3)
  destination  String       @db.VarChar(3)
  date         DateTime     @db.Date
  airlineCode  String?      @db.VarChar(10)
  flightNumber String?      @db.VarChar(10)
  cabinClass   CabinClass   @default(ECONOMY)
  departureAt  DateTime?
  arrivalAt    DateTime?
  durationMin  Int?
  stops        Int          @default(0)
  priceIdr     BigInt
  baggage      String?
  bookingUrl   String?
  scrapedAt    DateTime     @default(now())
  rawData      Json?

  @@index([origin, destination, date, airlineCode])
  @@index([scrapedAt(sort: Desc)])
  @@map("price_records")
}

model Alert {
  id                  String       @id @default(uuid())
  // Search criteria
  origin              String       @db.VarChar(3)
  destination         String       @db.VarChar(3)
  departureDateFrom   DateTime     @db.Date
  departureDateTo     DateTime     @db.Date
  airlineCode         String?      @db.VarChar(10)  // null = semua maskapai
  cabinClass          CabinClass   @default(ECONOMY)
  // Notification (WhatsApp via WAHA)
  phoneNumber         String       @db.VarChar(20)  // E.164: 62812xxxx
  maxPriceIdr         BigInt
  // Browser identity (anonymous user)
  clientId            String       @db.VarChar(64)
  // Status
  isActive            Boolean      @default(true)
  lastCheckedAt       DateTime?
  lastPriceSeen       BigInt?
  matchedDate         DateTime?    @db.Date     // tanggal yg trigger alert
  triggeredAt         DateTime?
  createdAt           DateTime     @default(now())

  notifications       NotificationLog[]

  @@index([isActive, departureDateFrom, departureDateTo])
  @@index([clientId])
  @@map("alerts")
}

model NotificationLog {
  id             String       @id @default(uuid())
  alert          Alert        @relation(fields: [alertId], references: [id], onDelete: Cascade)
  alertId        String
  source         FlightSource
  priceTriggered BigInt
  flightNumber   String?
  success        Boolean
  errorMessage   String?
  sentAt         DateTime     @default(now())

  @@map("notification_logs")
}
