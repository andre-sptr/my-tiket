# ─── Amadeus API ──────────────────────────────────────────────────────────────
# Daftar di https://developers.amadeus.com → My Apps → Create New App
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here
AMADEUS_HOSTNAME=test   # ganti ke "production" setelah go-live

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (docker-compose.yml)
DATABASE_URL=postgresql://mytiket:mytiket_dev_password@localhost:5432/mytiket

# Production (docker-compose.prod.yml — ganti password!)
# DATABASE_URL=postgresql://mytiket:STRONG_PASSWORD@postgres:5432/mytiket
POSTGRES_USER=mytiket
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev
REDIS_URL=redis://localhost:6379

# Production (dengan password)
# REDIS_URL=redis://:STRONG_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate: npm run vapid:generate (di folder backend/)
# Atau: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=generate_dengan_npm_run_vapid_generate
VAPID_PRIVATE_KEY=generate_dengan_npm_run_vapid_generate
VAPID_EMAIL=admin@tiket.andresptr.site

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000   # production: https://tiket.andresptr.site
