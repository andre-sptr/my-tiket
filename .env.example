# ─── Amadeus API ──────────────────────────────────────────────────────────────
# Daftar di https://developers.amadeus.com → My Apps → Create New App
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here
AMADEUS_HOSTNAME=test   # ganti ke "production" setelah go-live

# ─── Database (PostgreSQL native, bukan Docker) ───────────────────────────────
# Dev & prod sama-sama localhost karena Postgres install via apt
DATABASE_URL=postgresql://mytiket:mytiket_dev_password@localhost:5432/mytiket
# Production: GANTI password!
# DATABASE_URL=postgresql://mytiket:PASSWORD_KUAT@localhost:5432/mytiket

# ─── Redis (native, bukan Docker) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production dengan password (jika diaktifkan):
# REDIS_URL=redis://:REDIS_PASSWORD@localhost:6379

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate: cd backend && npm run vapid:generate
VAPID_PUBLIC_KEY=generate_dengan_npm_run_vapid_generate
VAPID_PRIVATE_KEY=generate_dengan_npm_run_vapid_generate
VAPID_EMAIL=admin@tiket.andresptr.site

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000   # production: https://tiket.andresptr.site

# ─── Scraper schedule (VPS resource-constrained) ─────────────────────────────
# Default: 120 menit (2 jam). Naikkan jika RAM kepepet.
CHECK_INTERVAL_MIN=120

# ─── Playwright Chromium ─────────────────────────────────────────────────────
# Pakai chromium dari apt, bukan download lagi
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
